<header class="header">
  <h1 class="header__title">Intentional Home Finds</h1>
  <p class="header__tagline">Curated picks for a home you'll love coming back to</p>
</header>

<style>
  .header {
    text-align: center;
    padding: 2.5rem 1rem 1.5rem;
    max-width: var(--max-width);
    width: 100%;
  }

  .header__title {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .header__tagline {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text-light);
    margin-top: 0.35rem;
  }

  @media (min-width: 640px) {
    .header {
      padding: 3rem 1rem 2rem;
    }

    .header__title {
      font-size: 2.25rem;
    }

    .header__tagline {
      font-size: 1.05rem;
    }
  }
</style>
