---
interface Props {
  title: string;
  image: string;
  link: string;
  description?: string;
  featured?: boolean;
}

const { title, image, link, description, featured } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="card">
  <div class="card__image-wrapper">
    <img src={image} alt={title} loading="lazy" />
    {featured && <span class="card__badge">Fave</span>}
  </div>
  <div class="card__body">
    <h2 class="card__title">{title}</h2>
    {description && <p class="card__description">{description}</p>}
    <span class="card__cta">Shop on Amazon &rarr;</span>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-white);
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: 0 2px 12px var(--color-shadow);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px var(--color-shadow);
  }

  .card:active {
    transform: translateY(-1px);
  }

  .card__image-wrapper {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--color-pink-light);
  }

  .card__image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card__badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--color-pink);
    color: var(--color-text);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .card__body {
    padding: 1rem;
  }

  .card__title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-text);
  }

  .card__description {
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--color-text-light);
    margin-top: 0.35rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__cta {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-pink-dark);
    margin-top: 0.5rem;
  }
</style>
